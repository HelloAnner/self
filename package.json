{
  "name": "@helloanner/self-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14 <1.4"
  },
  "workspaces": [
    "packages/*",
    "packages/platforms/*"
  ],
  "scripts": {
    "dev": "bun run src/cli/main.ts",
    "build": "bun run scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome check .",
    "check:size": "bun run scripts/check-size.ts",
    "db:check": "bun run scripts/sqlite-spike.ts --check-only",
    "check": "bun run typecheck && bun run lint && bun run check:size && bun test",
    "test": "bun test",
    "test:e2e": "bun run tests/harness/main.ts suite fast",
    "test:e2e:phase1": "bun run tests/harness/phase1.ts",
    "test:e2e:phase2": "bun run tests/harness/phase2.ts",
    "test:e2e:phase2.5": "bun run tests/harness/phase2_5.ts",
    "test:e2e:phase3": "bun run tests/harness/phase3.ts",
    "spike:sqlite": "bun run scripts/sqlite-spike.ts",
    "verify:phase0": "bun run scripts/verify-phase-0.ts",
    "verify:phase1": "bun run scripts/verify-phase-1.ts",
    "verify:phase2": "bun run scripts/verify-phase-2.ts",
    "verify:phase2.5": "bun run scripts/verify-phase-2-5.ts",
    "verify:phase3": "bun run scripts/verify-phase-3.ts",
    "package:local": "bun run scripts/build.ts"
  },
  "dependencies": {
    "@clack/prompts": "1.7.0",
    "@commander-js/extra-typings": "15.0.0",
    "commander": "15.0.0",
    "drizzle-orm": "0.45.2",
    "pdfjs-dist": "6.1.200",
    "smol-toml": "1.7.0",
    "sqlite-vec": "0.1.9",
    "uuid": "14.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@playwright/test": "1.61.1",
    "@types/bun": "1.3.14",
    "drizzle-kit": "0.31.10",
    "fast-check": "4.9.0",
    "typescript": "7.0.2"
  }
}
